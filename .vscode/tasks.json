{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Backend: Pytest",
      "type": "shell",
      "command": "${workspaceFolder}\\.venv\\Scripts\\python.exe",
      "args": [
        "-m",
        "pytest"
      ],
      "options": {
        "cwd": "${workspaceFolder}\\backend"
      },
      "group": "test",
      "problemMatcher": []
    },
    {
      "label": "Backend: Uvicorn",
      "type": "shell",
      "command": "${workspaceFolder}\\.venv\\Scripts\\python.exe",
      "args": [
        "-m",
        "uvicorn",
        "app.main:app",
        "--reload"
      ],
      "options": {
        "cwd": "${workspaceFolder}\\backend"
      },
      "isBackground": true,
      "problemMatcher": []
    },
    {
      "label": "Backend: PostgreSQL Smoke Test",
      "type": "shell",
      "command": "${workspaceFolder}\\.venv\\Scripts\\python.exe",
      "args": [
        "scripts/postgres_smoke_test.py",
        "--database-url",
        "${input:postgresDatabaseUrl}"
      ],
      "options": {
        "cwd": "${workspaceFolder}\\backend"
      },
      "problemMatcher": []
    },
    {
      "label": "Frontend: Install",
      "type": "shell",
      "command": "npm",
      "args": [
        "install"
      ],
      "options": {
        "cwd": "${workspaceFolder}\\frontend"
      },
      "problemMatcher": []
    },
    {
      "label": "Frontend: Dev",
      "type": "shell",
      "command": "npm",
      "args": [
        "run",
        "dev"
      ],
      "options": {
        "cwd": "${workspaceFolder}\\frontend"
      },
      "isBackground": true,
      "problemMatcher": []
    },
    {
      "label": "Frontend: Build",
      "type": "shell",
      "command": "npm",
      "args": [
        "run",
        "build"
      ],
      "options": {
        "cwd": "${workspaceFolder}\\frontend"
      },
      "group": "build",
      "problemMatcher": []
    },
    {
        "label": "Frontend: Test",
        "type": "shell",
        "command": "npm",
        "args": [
          "run",
          "test"
        ],
        "options": {
          "cwd": "${workspaceFolder}\\frontend"
        },
        "group": "test",
        "problemMatcher": []
      },
      {
      "label": "Frontend: Lint",
      "type": "shell",
      "command": "npm",
      "args": [
        "run",
        "lint"
      ],
      "options": {
        "cwd": "${workspaceFolder}\\frontend"
      },
      "group": "test",
      "problemMatcher": []
    }
  ],
  "inputs": [
    {
      "id": "postgresDatabaseUrl",
      "type": "promptString",
      "description": "Disposable PostgreSQL DATABASE_URL",
      "default": "postgresql+psycopg://postgres:postgres@localhost:5432/ai_match_mvp"
    }
  ]
}